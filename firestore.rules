rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Restaurant data: readable by anyone authenticated, writable by merchant
    match /restaurants/{restaurantId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      match /menu/{menuItem} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    // User profiles: only the owner can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Orders: allow customer to read/create their own orders, allow restaurant to read/update orders
    match /orders/{orderId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.customerId;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.customerId || request.auth.uid == resource.data.restaurantId);
    }
  }
}
